    .actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end}
    .btn{border:1px solid var(--line);background:rgba(245,243,238,.08);color:var(--cream);padding:11px 14px;border-radius:14px;cursor:pointer;text-decoration:none;display:inline-flex;gap:8px;align-items:center;white-space:nowrap;font-weight:750;transition:.16s ease}
    .btn.primary{background:var(--amber);border-color:var(--amber);color:#fff;font-weight:900}.btn.blue{background:var(--blue);border-color:var(--blue);color:white}.btn:hover{filter:brightness(1.07);transform:translateY(-1px)}
    .notice{margin:16px auto 0;width:min(var(--max),calc(100% - 32px));display:none;border:1px solid rgba(217,119,6,.35);background:rgba(217,119,6,.12);border-radius:16px;padding:12px 14px;color:#ffe8c2;font-size:13px}.notice.show{display:block}
    .toolbar{padding:18px 0;display:grid;grid-template-columns:1fr .72fr .72fr .72fr .95fr;gap:12px}.field{background:rgba(245,243,238,.08);border:1px solid var(--line);border-radius:16px;padding:10px 12px}.field label{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.09em;color:var(--muted);margin-bottom:5px}.field select,.field input{width:100%;background:transparent;border:0;color:var(--cream);outline:0}.field option{color:#111}.field input::placeholder{color:rgba(245,243,238,.45)}
    .tabs{display:flex;gap:8px;overflow:auto;padding:4px 0 20px}.tab{border:1px solid var(--line);background:rgba(245,243,238,.08);color:var(--cream);padding:10px 13px;border-radius:999px;cursor:pointer;white-space:nowrap;font-weight:800}.tab.active{background:var(--cream);color:var(--green);font-weight:950;border-color:var(--cream)}
    .status-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin:2px 0 18px}.stat{background:linear-gradient(180deg,rgba(245,243,238,.1),rgba(245,243,238,.065));border:1px solid var(--line);border-radius:20px;padding:16px;min-height:88px}.stat .k{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}.stat .v{font-size:26px;font-weight:950;margin-top:6px}.stat small{display:block;color:var(--muted2);margin-top:2px}
    .layout{display:grid;grid-template-columns:1.35fr 1fr;gap:16px}.panel{background:rgba(245,243,238,.075);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden}.panel-head{display:flex;justify-content:space-between;gap:12px;align-items:center;padding:16px 18px;border-bottom:1px solid var(--line)}.panel-head h2{font-size:18px;margin:0}.panel-head small{color:var(--muted2)}
    .calendar{padding:12px}.week,.days{display:grid;grid-template-columns:repeat(7,1fr);gap:8px}.week{margin-bottom:8px}.week div{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;text-align:center}.day{min-height:98px;background:rgba(255,255,255,.04);border:1px solid var(--line);border-radius:16px;padding:9px;cursor:pointer;transition:.15s ease}.day.empty{opacity:.23;cursor:default}.day:hover{border-color:rgba(245,243,238,.35);transform:translateY(-1px)}.day.active{outline:2px solid var(--amber);background:rgba(217,119,6,.13)}.day-num{font-weight:950}.chips{display:flex;flex-wrap:wrap;gap:4px;margin-top:8px}.chip{font-size:10px;line-height:1;padding:5px 6px;border-radius:999px;background:rgba(245,243,238,.11);border:1px solid rgba(245,243,238,.12);color:var(--cream)}.chip.Carrusel{background:rgba(29,78,216,.22)}.chip.Post{background:rgba(20,83,45,.28)}.chip.Historia{background:rgba(217,119,6,.22)}.chip.Reel{background:rgba(190,54,20,.22)}
    .day-detail{padding:12px 14px;display:grid;gap:10px;max-height:520px;overflow:auto}.detail-card{border:1px solid var(--line);border-radius:17px;background:rgba(255,255,255,.055);padding:12px}.meta{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:8px}.pill{font-size:11px;padding:6px 8px;border-radius:999px;background:rgba(245,243,238,.1);border:1px solid rgba(245,243,238,.12);font-weight:850}.pill.format{background:rgba(20,83,45,.35)}.detail-card h3{margin:0 0 8px;font-size:15px}.copy{font-size:13px;color:var(--muted);line-height:1.45}.rowlinks{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}.linkbtn{font-size:12px;text-decoration:none;border:1px solid var(--line);border-radius:999px;padding:7px 9px;color:var(--cream);background:rgba(245,243,238,.07)}
    .visual-panel{margin:18px 0 26px}.view-switch{display:flex;gap:9px;flex-wrap:wrap}.view-btn{border:0;border-radius:999px;padding:11px 14px;cursor:pointer;font-weight:950}.view-btn.active{background:var(--green2);color:white}.view-btn:not(.active){background:var(--cream);color:var(--green)}.view{display:none;padding:18px}.view.active{display:block}
    .feed{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.feed-card{background:var(--cream);color:#10291d;border-radius:22px;overflow:hidden;box-shadow:var(--shadow);border:1px solid rgba(0,0,0,.08)}.thumb{aspect-ratio:4/5;background:linear-gradient(140deg,#0b1f16,#14532D);display:grid;place-items:center;position:relative;overflow:hidden}.thumb img{width:100%;height:100%;object-fit:cover;display:block}.thumb .placeholder{display:grid;place-items:center;text-align:center;color:var(--cream);padding:18px}.thumb .placeholder img{width:140px;height:auto;object-fit:contain;background:rgba(245,243,238,.95);border-radius:14px;padding:10px;margin-bottom:12px}.badge{position:absolute;top:12px;left:12px;background:rgba(6,20,15,.86);color:white;border-radius:999px;padding:7px 9px;font-size:11px;font-weight:900}.badge.right{left:auto;right:12px;background:var(--amber)}.badge.pauta{top:auto;left:12px;bottom:12px;background:#111827}.badge.pauta.si{background:#16a34a}.badge.pauta.no{background:#64748b}.badge.pauta.pendiente{background:#d97706}.badge.pauta.remarketing{background:#7c3aed}.pill.pauta{background:rgba(22,163,74,.22);border-color:rgba(22,163,74,.35)}.pill.pauta.no{background:rgba(100,116,139,.22);border-color:rgba(100,116,139,.35)}.pill.pauta.pendiente{background:rgba(217,119,6,.22);border-color:rgba(217,119,6,.35)}.feed-body{padding:14px}.feed-body h3{margin:0 0 8px;font-size:15px;line-height:1.25}.feed-body p{margin:0;color:#516257;font-size:13px;line-height:1.4}.feed-foot{display:flex;justify-content:space-between;gap:8px;align-items:center;margin-top:12px;color:#607166;font-size:12px}
    .carousel-wrap{display:grid;grid-template-columns:1fr .88fr;gap:18px;align-items:center}.carousel-stage{background:var(--cream);border-radius:26px;overflow:hidden;box-shadow:var(--shadow);min-height:500px}.carousel-image{aspect-ratio:4/5;background:linear-gradient(140deg,#0b1f16,#14532D);position:relative;display:grid;place-items:center}.carousel-image img{width:100%;height:100%;object-fit:cover}.carousel-info{background:rgba(245,243,238,.09);border:1px solid var(--line);border-radius:24px;padding:20px}.carousel-info h3{font-size:28px;margin:10px 0}.carousel-info p{color:var(--muted);line-height:1.55}.carousel-controls{display:flex;gap:10px;margin-top:16px}.carousel-controls button{border:0;border-radius:14px;background:var(--cream);color:var(--green);padding:11px 14px;font-weight:950;cursor:pointer}.dots{display:flex;gap:6px;flex-wrap:wrap;margin-top:14px}.dot{width:9px;height:9px;border-radius:50%;background:rgba(245,243,238,.3)}.dot.active{background:var(--amber)}
    table{width:100%;border-collapse:collapse;font-size:13px}th,td{padding:10px;border-bottom:1px solid var(--line);text-align:left;vertical-align:top}th{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.08em;background:rgba(245,243,238,.05);position:sticky;top:0}td a{color:#e5f0ff}.table-scroll{max-height:620px;overflow:auto;border:1px solid var(--line);border-radius:18px}
    .verify-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.verify-card{border:1px solid var(--line);border-radius:18px;background:rgba(255,255,255,.055);padding:14px}.verify-card b{display:block;font-size:18px;margin-top:6px}.ok{color:#9fe6b4}.bad{color:#ffb38a}.muted{color:var(--muted2)}.code{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:12px;word-break:break-all;background:rgba(0,0,0,.28);padding:8px;border-radius:10px;margin-top:8px;color:#d7e6dc}
    .manual{display:none;padding:18px}.manual.show{display:block}.manual textarea{width:100%;min-height:170px;background:rgba(0,0,0,.22);border:1px solid var(--line);color:var(--cream);border-radius:16px;padding:14px;outline:0}.manual .manual-row{display:flex;gap:10px;margin-top:10px;flex-wrap:wrap}
    footer{padding:26px 0 38px;color:var(--muted);text-align:center;font-size:12px}
    @media (max-width:1100px){.status-grid{grid-template-columns:repeat(3,1fr)}.layout,.carousel-wrap{grid-template-columns:1fr}.toolbar{grid-template-columns:1fr 1fr}.feed{grid-template-columns:repeat(2,1fr)}}
    @media (max-width:720px){.hero-row{align-items:flex-start;flex-direction:column}.actions{justify-content:flex-start}.toolbar,.status-grid,.feed,.verify-grid{grid-template-columns:1fr}.calendar .day{min-height:72px}.day-detail{max-height:none}.logoBox{width:64px;height:48px}}
  </style>
</head>
<body>
  <header class="hero">
    <div class="wrap hero-row">
      <div class="brand">
        <div class="logoBox"><img src="https://trekkinghouseperu.pe/wp-content/uploads/2024/02/logo-trasnparente-1024x520.png.webp" alt="Trekking House Perú"></div>
        <div>
          <h1>Grilla de Contenido 2026</h1>
          <p class="sub">Trekking House Perú · Google Sheets + Apps Script + Drive</p>
        </div>
      </div>
      <div class="actions">
        <button class="btn" id="refreshBtn">Actualizar data</button>
        <button class="btn" id="verifyBtn">Verificación</button>
        <a class="btn" id="openSheet" target="_blank" rel="noopener">Abrir Sheet</a>
        <a class="btn" id="openWeb" target="_blank" rel="noopener">Web publicada</a>
        <a class="btn" id="openCsv" target="_blank" rel="noopener">CSV</a>
        <button class="btn primary" id="manualBtn">Carga manual CSV</button>
      </div>
    </div>
    <div class="notice" id="notice"></div>
  </header>

  <main class="wrap">
    <section class="toolbar">
      <div class="field"><label>Mes</label><select id="monthSelect"></select></div>
      <div class="field"><label>Formato</label><select id="formatSelect"><option value="Todos">Todos</option><option>Carrusel</option><option>Post</option><option>Historia</option><option>Reel</option></select></div>
      <div class="field"><label>Estado</label><select id="statusSelect"><option value="Todos">Todos</option><option>Pendiente</option><option>Diseño</option><option>Aprobado</option><option>Publicado</option></select></div>
      <div class="field"><label>Pauta</label><select id="pautaSelect"><option value="Todos">Todos</option><option value="si">Sí pauta</option><option value="no">No pauta / orgánico</option><option value="pendiente">Pendiente</option><option value="remarketing">Remarketing</option></select></div>
      <div class="field"><label>Buscar</label><input id="searchInput" placeholder="Título, copy, producto, campaña..." /></div>
    </section>

    <section class="tabs" id="monthTabs"></section>

    <section class="status-grid">
      <div class="stat"><div class="k">Piezas del mes</div><div class="v" id="statTotal">0</div><small id="statSource">Sin cargar</small></div>
      <div class="stat"><div class="k">Carruseles</div><div class="v" id="statCarrusel">0</div><small>Slides múltiples</small></div>
      <div class="stat"><div class="k">Posts</div><div class="v" id="statPost">0</div><small>Feed estático</small></div>
      <div class="stat"><div class="k">Historias</div><div class="v" id="statHistoria">0</div><small>Stories / WhatsApp</small></div>
      <div class="stat"><div class="k">Reels</div><div class="v" id="statReel">0</div><small>Video corto</small></div>
      <div class="stat"><div class="k">En pauta</div><div class="v" id="statPauta">0</div><small>Desde columna Pauta</small></div>
    </section>

    <section class="layout">
      <div class="panel">
        <div class="panel-head"><h2>Calendario</h2><small id="calendarStatus">Sin cargar</small></div>
        <div class="calendar"><div class="week"><div>Lun</div><div>Mar</div><div>Mié</div><div>Jue</div><div>Vie</div><div>Sáb</div><div>Dom</div></div><div class="days" id="calendarDays"></div></div>
      </div>
      <div class="panel">
        <div class="panel-head"><h2>Detalle del día</h2><small id="detailCount">0 piezas</small></div>
        <div class="day-detail" id="dayDetail"></div>
      </div>
    </section>

    <section class="panel visual-panel">
      <div class="panel-head">
        <h2>Vista visual del contenido</h2>
        <div class="view-switch">
          <button class="view-btn active" data-view="feedView">Feed 3 columnas</button>
          <button class="view-btn" data-view="carouselView">Carrusel visual</button>
          <button class="view-btn" data-view="tableView">Tabla operativa</button>
          <button class="view-btn" data-view="verifyView">Verificación</button>
        </div>
      </div>
      <div class="view active" id="feedView"><div class="feed" id="feed"></div></div>
      <div class="view" id="carouselView"><div id="carouselMount"></div></div>
      <div class="view" id="tableView"><div class="table-scroll"><table><thead><tr><th>Fecha</th><th>Formato</th><th>Pauta</th><th>Título</th><th>Copy</th><th>CTA</th><th>Campaña</th><th>Producto</th><th>Links</th></tr></thead><tbody id="tableBody"></tbody></table></div></div>
      <div class="view" id="verifyView"><div id="verifyMount"></div></div>
      <div class="manual" id="manualBox">
        <h3>Carga manual CSV</h3>
        <p class="muted">Pega aquí el CSV publicado si Google Sheets demora en actualizar o si GitHub bloquea temporalmente la lectura.</p>
        <textarea id="manualCsv" placeholder="Pega aquí el contenido CSV..."></textarea>
        <div class="manual-row"><button class="btn primary" id="applyManualCsv">Aplicar CSV manual</button><button class="btn" id="closeManual">Cerrar</button></div>
      </div>
    </section>
  </main>

  <footer>THP · Grilla conectada a Google Sheets. Incluye etiqueta de pauta desde Google Sheets. Recomendado: Apps Script como endpoint principal.</footer>

<script>
(() => {
  'use strict';

  const CONFIG = {
    logoUrl: 'https://trekkinghouseperu.pe/wp-content/uploads/2024/02/logo-trasnparente-1024x520.png.webp',
    editableSheetUrl: 'https://docs.google.com/spreadsheets/d/1ERZPxlESqt8yAUdkg_UcVwQc-VQ9xgkygVnzFUUx-8A/edit?gid=1394940075#gid=1394940075',
    spreadsheetId: '1ERZPxlESqt8yAUdkg_UcVwQc-VQ9xgkygVnzFUUx-8A',
    sheetName: 'Contenido',
    gid: '1394940075',
    publishedWebUrl: 'https://docs.google.com/spreadsheets/d/e/2PACX-1vT4mT-mL0RqI_Mo1aNkpBIsXr_2b1CUFn33KDmuB9Y1xWbuWNfngnGmErfuGjlXlmhGhKh-I9qYZXXH/pubhtml',
    publishedCsvUrl: 'https://docs.google.com/spreadsheets/d/e/2PACX-1vT4mT-mL0RqI_Mo1aNkpBIsXr_2b1CUFn33KDmuB9Y1xWbuWNfngnGmErfuGjlXlmhGhKh-I9qYZXXH/pub?gid=1394940075&single=true&output=csv',
    // Pega aquí la URL del Web App de Apps Script cuando lo despliegues. El HTML funcionará mejor con esa URL.
    appsScriptUrl: '',
    expected: { Junio: 24, Julio: 81 }
  };

  const MONTHS = ['Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const MONTH_NUM = {Junio:5, Julio:6, Agosto:7, Septiembre:8, Octubre:9, Noviembre:10, Diciembre:11};
  const HEADER_ALIASES = {
    'ID':['ID'], 'Mes':['Mes'], 'Fecha':['Fecha'], 'Día':['Día','Dia'], 'Semana':['Semana'], 'Formato':['Formato'],
    'Cantidad slides':['Cantidad slides','Cantidad de slides','Slides'], 'Categoría':['Categoría','Categoria'], 'Pilar contenido':['Pilar contenido'],
    'Título pieza':['Título pieza','Titulo pieza','Titulo','Título'], 'Objetivo':['Objetivo'], 'Copy ≤25 palabras':['Copy ≤25 palabras','Copy <=25 palabras','Copy','Copy publicación'],
    'CTA':['CTA'], 'Estado':['Estado'], 'Link slide 1':['Link slide 1'], 'Link slide 2':['Link slide 2'], 'Link slide 3':['Link slide 3'],
    'Link slide 4':['Link slide 4'], 'Link slide 5':['Link slide 5'], 'Link slide 6':['Link slide 6'], 'Link producto':['Link producto'],
    'Canal':['Canal'], 'Responsable':['Responsable'], 'Prioridad':['Prioridad'], 'Pauta':['Pauta','Pauta / Ads','Pauta Ads','Va en pauta','¿Va en pauta?','Irá en pauta','Ira en pauta','Ads','Paid'], 'Campaña':['Campaña','Campana'], 'Fuente / brief':['Fuente / brief'],
    'Outfit base':['Outfit base'], 'Pregunta para anuncio':['Pregunta para anuncio'], 'Respuesta bot inicial':['Respuesta bot inicial'], 'Observaciones':['Observaciones'],
    'Validación copy':['Validación copy','Validacion copy'], 'Cantidad links':['Cantidad links']
  };

  let DATA = [];
  let DATA_SOURCE = 'sin cargar';
  let SELECTED_DAY = null;
  let carouselIndex = 0;

  const $ = (sel) => document.querySelector(sel);
  const $$ = (sel) => [...document.querySelectorAll(sel)];
  const esc = (s='') => String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m]));
  const norm = (s='') => String(s).trim().normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase().replace(/\s+/g,' ');
  const words = (s='') => String(s).trim().split(/\s+/).filter(Boolean).length;
  const get = (obj, key) => obj[key] || '';

  function showNotice(msg, type='warn'){
    const n = $('#notice');
    n.textContent = msg;
    n.classList.add('show');
    n.style.borderColor = type === 'ok' ? 'rgba(120,220,150,.35)' : 'rgba(217,119,6,.35)';
    n.style.background = type === 'ok' ? 'rgba(20,83,45,.20)' : 'rgba(217,119,6,.12)';
  }
  function hideNotice(){ $('#notice').classList.remove('show'); }

  function setupLinks(){
    $('#openSheet').href = CONFIG.editableSheetUrl;
    $('#openWeb').href = CONFIG.publishedWebUrl;
    $('#openCsv').href = CONFIG.publishedCsvUrl;
  }

  function canonicalizeRow(row){
    const out = {};
    for(const [canonical, aliases] of Object.entries(HEADER_ALIASES)){
      let val = '';
      for(const a of aliases){
        if(row[a] !== undefined && row[a] !== null && String(row[a]).trim() !== '') { val = row[a]; break; }
      }
      out[canonical] = val;
    }
    out._date = parseDate(out.Fecha, out.Mes);
    out._dateKey = out._date ? out._date.toISOString().slice(0,10) : '';
    out._format = normalizeFormat(out.Formato);
    out._pauta = normalizePauta(out.Pauta);
    out._slides = slideLinks(out);
    out._wordCount = words(out['Copy ≤25 palabras']);
    return out;
  }

  function normalizeFormat(f){
    const n = norm(f);
    if(n.includes('carrusel')) return 'Carrusel';
    if(n.includes('historia')) return 'Historia';
    if(n.includes('reel')) return 'Reel';
    if(n.includes('post')) return 'Post';
    return f || 'Sin formato';
  }

  function normalizePauta(value){
    const raw = String(value || '').trim();
    const n = norm(raw);
    if(!n) return {raw:'', key:'pendiente', label:'Pendiente pauta'};
    if(n.includes('remarketing') || n.includes('retarget')) return {raw, key:'remarketing', label:raw};
    if(n.includes('no') || n.includes('organico') || n.includes('orgánico')) return {raw, key:'no', label:raw || 'No pauta'};
    if(n.includes('si') || n.includes('sí') || n.includes('pauta') || n.includes('ads') || n.includes('paid') || n.includes('meta') || n.includes('tiktok')) return {raw, key:'si', label:raw || 'Sí pauta'};
    if(n.includes('pendiente') || n.includes('definir')) return {raw, key:'pendiente', label:raw};
    return {raw, key:'si', label:raw};
  }

  function pautaBadge(r){
    const p = r._pauta || normalizePauta(r.Pauta);
    return `<span class="badge pauta ${esc(p.key)}">${esc(p.label)}</span>`;
  }

  function pautaPill(r){
    const p = r._pauta || normalizePauta(r.Pauta);
    return `<span class="pill pauta ${esc(p.key)}">${esc(p.label)}</span>`;
  }

  function parseDate(value, mes){
    if(value instanceof Date && !isNaN(value)) return value;
    const raw = String(value || '').trim();
    if(!raw) return null;
    let m;
    if((m = raw.match(/^(\d{4})[-/](\d{1,2})[-/](\d{1,2})$/))){
      return new Date(Number(m[1]), Number(m[2])-1, Number(m[3]));
    }
    if((m = raw.match(/^(\d{1,2})[/-](\d{1,2})(?:[/-](\d{2,4}))?$/))){
      let y = m[3] ? Number(m[3]) : 2026;
      if(y < 100) y += 2000;
      return new Date(y, Number(m[2])-1, Number(m[1]));
    }
    const d = new Date(raw);
    if(!isNaN(d)) return d;
    const mn = MONTH_NUM[mes] ?? 6;
    return new Date(2026, mn, 1);
  }

  function slideLinks(row){
    const links = [];
    for(let i=1;i<=6;i++){
      const raw = String(row[`Link slide ${i}`] || '').trim();
      if(raw) links.push(raw);
    }
    return links;
  }

  function driveToImg(url){
    if(!url) return '';
    const s = String(url).trim();
    let m = s.match(/\/file\/d\/([^/]+)/) || s.match(/[?&]id=([^&]+)/) || s.match(/open\?id=([^&]+)/);
    if(m && m[1]) return `https://drive.google.com/thumbnail?id=${encodeURIComponent(m[1])}&sz=w1600`;
    return s;
  }

  function parseCsv(text){
    const rows = [];
    let row = [], val = '', q = false;
    for(let i=0;i<text.length;i++){
      const c = text[i], n = text[i+1];
      if(q){
        if(c === '"' && n === '"'){ val += '"'; i++; }
        else if(c === '"'){ q = false; }
        else val += c;
      } else {
        if(c === '"') q = true;
        else if(c === ','){ row.push(val); val=''; }
        else if(c === '\n'){ row.push(val); rows.push(row); row=[]; val=''; }
        else if(c !== '\r') val += c;
      }
    }
    if(val || row.length){ row.push(val); rows.push(row); }
    return rows.filter(r => r.some(x => String(x).trim() !== ''));
  }

  function rowsToObjects(rows){
    if(!rows.length) return [];
    const headers = rows[0].map(h => String(h).trim());
    return rows.slice(1).map(r => Object.fromEntries(headers.map((h,i)=>[h, r[i] || '']))).filter(o => Object.values(o).some(v => String(v).trim()));
  }

  function gvizRowsToObjects(table){
    const cols = (table.cols || []).map(c => String(c.label || c.id || '').trim());
    const rows = table.rows || [];
    return rows.map(r => {
      const obj = {};
      (r.c || []).forEach((cell, i) => { obj[cols[i]] = cell ? (cell.f ?? cell.v ?? '') : ''; });
      return obj;
    }).filter(o => Object.values(o).some(v => String(v).trim()));
  }

  function fetchGvizJsonp(){
    return new Promise((resolve, reject) => {
      const cbName = 'thpGvizCallback_' + Math.random().toString(36).slice(2);
      const url = `https://docs.google.com/spreadsheets/d/${CONFIG.spreadsheetId}/gviz/tq?tqx=responseHandler:${cbName};out:json&gid=${CONFIG.gid}&headers=1&cachebust=${Date.now()}`;
      const script = document.createElement('script');
      const timer = setTimeout(() => { cleanup(); reject(new Error('Timeout GViz JSONP')); }, 12000);
      function cleanup(){ clearTimeout(timer); delete window[cbName]; script.remove(); }
      window[cbName] = (payload) => {
        cleanup();
        if(payload && payload.table) resolve(gvizRowsToObjects(payload.table));
        else reject(new Error('GViz sin tabla'));
      };
      script.onerror = () => { cleanup(); reject(new Error('Error cargando GViz')); };
      script.src = url;
      document.body.appendChild(script);
    });
  }

  function fetchAppsScriptJsonp(){
    if(!CONFIG.appsScriptUrl) return Promise.reject(new Error('Apps Script URL no configurada'));
    return new Promise((resolve, reject) => {
      const cbName = 'thpAppsCallback_' + Math.random().toString(36).slice(2);
      const sep = CONFIG.appsScriptUrl.includes('?') ? '&' : '?';
      const url = `${CONFIG.appsScriptUrl}${sep}callback=${cbName}&cachebust=${Date.now()}`;
      const script = document.createElement('script');
      const timer = setTimeout(() => { cleanup(); reject(new Error('Timeout Apps Script')); }, 12000);
      function cleanup(){ clearTimeout(timer); delete window[cbName]; script.remove(); }
      window[cbName] = (payload) => {
        cleanup();
        if(payload && payload.ok && Array.isArray(payload.rows)) resolve(payload.rows);
        else reject(new Error(payload && payload.error ? payload.error : 'Apps Script sin filas'));
      };
      script.onerror = () => { cleanup(); reject(new Error('Error cargando Apps Script')); };
      script.src = url;
      document.body.appendChild(script);
    });
  }

  async function fetchCsv(){
    const url = CONFIG.publishedCsvUrl + '&cachebust=' + Date.now();
    const res = await fetch(url, {cache:'no-store'});
    if(!res.ok) throw new Error('CSV HTTP ' + res.status);
    const text = await res.text();
    return rowsToObjects(parseCsv(text));
  }

  async function loadData(){
    hideNotice();
    $('#statSource').textContent = 'Cargando...';
    const attempts = [];
    try{
      const rows = await fetchAppsScriptJsonp();
      attempts.push('apps-script: OK');
      setData(rows, 'apps-script'); return;
    }catch(e){ attempts.push('apps-script: ' + e.message); }
    try{
      const rows = await fetchGvizJsonp();
      attempts.push('gviz-jsonp: OK');
      setData(rows, 'gviz-jsonp'); return;
    }catch(e){ attempts.push('gviz-jsonp: ' + e.message); }
    try{
      const rows = await fetchCsv();
      attempts.push('csv: OK');
      setData(rows, 'csv'); return;
    }catch(e){ attempts.push('csv: ' + e.message); }
    DATA = [];
    DATA_SOURCE = 'falló conexión';
    renderAll();
    showNotice('No se pudo cargar la data. Revisa la pestaña Verificación o usa Carga manual CSV. Intentos: ' + attempts.join(' | '));
  }

  function setData(rows, source){
    DATA = rows.map(canonicalizeRow).filter(r => get(r,'ID') || get(r,'Título pieza'));
    DATA_SOURCE = source;
    const july = DATA.filter(r => r.Mes === 'Julio').length;
    if(july !== 81) showNotice(`Data cargada por ${source}, pero julio tiene ${july}/81 piezas. Revisa publicación/caché del Sheet.`, july ? 'warn' : 'warn');
    else showNotice(`Data cargada correctamente por ${source}. Julio: 81/81 piezas.`, 'ok');
    setupMonths();
    renderAll();
  }

  function setupMonths(){
    const select = $('#monthSelect');
    const current = select.value || 'Julio';
    select.innerHTML = MONTHS.map(m => `<option ${m===current?'selected':''}>${m}</option>`).join('');
    $('#monthTabs').innerHTML = MONTHS.map(m => `<button class="tab ${m===select.value?'active':''}" data-month="${m}">${m}</button>`).join('');
    $$('#monthTabs .tab').forEach(b => b.addEventListener('click', () => { select.value = b.dataset.month; SELECTED_DAY=null; renderAll(); }));
  }

  function filters(){
    return {month: $('#monthSelect').value || 'Julio', format: $('#formatSelect').value, status: $('#statusSelect').value, pauta: $('#pautaSelect').value, q: norm($('#searchInput').value)};
  }
  function filteredData(){
    const f = filters();
    return DATA.filter(r => {
      if(r.Mes !== f.month) return false;
      if(f.format !== 'Todos' && r._format !== f.format) return false;
      if(f.status !== 'Todos' && get(r,'Estado') !== f.status) return false;
      if(f.pauta !== 'Todos' && ((r._pauta && r._pauta.key) || 'pendiente') !== f.pauta) return false;
      if(f.q){
        const hay = [r.ID,r.Mes,r.Formato,r.Categoría,r['Pilar contenido'],r['Título pieza'],r.Objetivo,r['Copy ≤25 palabras'],r.CTA,r.Campaña,r['Fuente / brief'],r['Outfit base'],r['Link producto'],r.Pauta].join(' ');
        if(!norm(hay).includes(f.q)) return false;
      }
      return true;
    });
  }

  function renderAll(){
    $$('#monthTabs .tab').forEach(b => b.classList.toggle('active', b.dataset.month === ($('#monthSelect').value||'Julio')));
    renderStats(); renderCalendar(); renderDayDetail(); renderFeed(); renderCarousel(); renderTable(); renderVerify();
  }

  function renderStats(){
    const rows = filteredData();
    const count = fmt => rows.filter(r => r._format === fmt).length;
    $('#statTotal').textContent = rows.length;
    $('#statCarrusel').textContent = count('Carrusel');
    $('#statPost').textContent = count('Post');
    $('#statHistoria').textContent = count('Historia');
    $('#statReel').textContent = count('Reel');
    $('#statPauta').textContent = rows.filter(r => (r._pauta && (r._pauta.key === 'si' || r._pauta.key === 'remarketing'))).length;
    $('#statSource').textContent = DATA_SOURCE;
  }

  function renderCalendar(){
    const month = $('#monthSelect').value || 'Julio';
    const rows = filteredData();
    const mIndex = MONTH_NUM[month] ?? 6;
    const year = 2026;
    const first = new Date(year, mIndex, 1);
    const last = new Date(year, mIndex + 1, 0);
    const startOffset = (first.getDay() + 6) % 7;
    const byDate = groupBy(rows, r => r._dateKey);
    const cells = [];
    for(let i=0;i<startOffset;i++) cells.push(`<div class="day empty"></div>`);
    for(let d=1; d<=last.getDate(); d++){
      const date = new Date(year, mIndex, d);
      const key = date.toISOString().slice(0,10);
      const list = byDate[key] || [];
      const active = SELECTED_DAY === key ? 'active' : '';
      cells.push(`<div class="day ${active}" data-day="${key}"><div class="day-num">${d}</div><div class="chips">${list.slice(0,5).map(x=>`<span class="chip ${x._format}">${x._format}</span>`).join('')}${list.length>5?`<span class="chip">+${list.length-5}</span>`:''}</div></div>`);
    }
    $('#calendarDays').innerHTML = cells.join('');
    $('#calendarStatus').textContent = rows.length ? `${rows.length} piezas` : 'Sin piezas';
    $$('#calendarDays .day:not(.empty)').forEach(el => el.addEventListener('click', () => { SELECTED_DAY = el.dataset.day; renderCalendar(); renderDayDetail(); }));
  }

  function renderDayDetail(){
    const rows = filteredData();
    let selected = SELECTED_DAY;
    if(!selected && rows.length) selected = rows[0]._dateKey;
    const list = selected ? rows.filter(r => r._dateKey === selected) : [];
    $('#detailCount').textContent = `${list.length} piezas`;
    $('#dayDetail').innerHTML = list.length ? list.map(detailCard).join('') : `<div class="muted">Selecciona un día del calendario o carga información desde Google Sheets.</div>`;
  }

  function detailCard(r){
    const product = r['Link producto'] ? `<a class="linkbtn" href="${esc(r['Link producto'])}" target="_blank" rel="noopener">Producto</a>` : '';
    const slides = r._slides.length ? `<a class="linkbtn" href="${esc(r._slides[0])}" target="_blank" rel="noopener">Pieza gráfica</a>` : '';
    return `<article class="detail-card"><div class="meta"><span class="pill format">${esc(r._format)}</span><span class="pill">${esc(r.Fecha)}</span><span class="pill">${esc(r.Estado || 'Pendiente')}</span>${pautaPill(r)}<span class="pill">${r._slides.length} links</span></div><h3>${esc(r['Título pieza'])}</h3><div class="copy">${esc(r['Copy ≤25 palabras'])}</div><div class="rowlinks">${slides}${product}<span class="linkbtn">CTA: ${esc(r.CTA)}</span></div></article>`;
  }

  function renderFeed(){
    const rows = filteredData();
    $('#feed').innerHTML = rows.length ? rows.map(r => {
      const img = driveToImg(r._slides[0]);
      const thumb = img ? `<img loading="lazy" src="${esc(img)}" alt="${esc(r['Título pieza'])}">` : `<div class="placeholder"><img src="${esc(CONFIG.logoUrl)}" alt="THP"><strong>${esc(r._format)}</strong><span>${esc(r['Título pieza'])}</span></div>`;
      const slidesLabel = r._format === 'Carrusel' ? `${r['Cantidad slides'] || r._slides.length || 1} slides` : r._format;
      return `<article class="feed-card"><div class="thumb">${thumb}<span class="badge">${esc(r._format)}</span><span class="badge right">${esc(slidesLabel)}</span>${pautaBadge(r)}</div><div class="feed-body"><h3>${esc(r['Título pieza'])}</h3><p>${esc(r['Copy ≤25 palabras'])}</p><div class="feed-foot"><span>${esc(r.Fecha)}</span><span>${esc(r.Campaña || r.Categoría)}</span></div></div></article>`;
    }).join('') : `<div class="muted">No hay piezas para los filtros actuales.</div>`;
  }

  function renderCarousel(){
    const rows = filteredData();
    if(!rows.length){ $('#carouselMount').innerHTML = '<div class="muted">No hay piezas para mostrar.</div>'; return; }
    if(carouselIndex >= rows.length) carouselIndex = 0;
    const r = rows[carouselIndex];
    const img = driveToImg(r._slides[0]);
    const image = img ? `<img src="${esc(img)}" alt="${esc(r['Título pieza'])}">` : `<div class="placeholder"><img src="${esc(CONFIG.logoUrl)}" alt="THP"><strong>${esc(r._format)}</strong><span>${esc(r['Título pieza'])}</span></div>`;
    $('#carouselMount').innerHTML = `<div class="carousel-wrap"><div class="carousel-stage"><div class="carousel-image">${image}<span class="badge">${esc(r._format)}</span>${pautaBadge(r)}</div></div><aside class="carousel-info"><span class="pill format">${esc(r._format)}</span><span class="pill">${esc(r.Fecha)}</span>${pautaPill(r)}<h3>${esc(r['Título pieza'])}</h3><p>${esc(r['Copy ≤25 palabras'])}</p><p><b>CTA:</b> ${esc(r.CTA)}<br><b>Campaña:</b> ${esc(r.Campaña || '—')}<br><b>Pauta:</b> ${esc((r._pauta && r._pauta.label) || 'Pendiente pauta')}<br><b>Links cargados:</b> ${r._slides.length}</p><div class="carousel-controls"><button id="prevCar">Anterior</button><button id="nextCar">Siguiente</button></div><div class="dots">${rows.slice(0,60).map((_,i)=>`<span class="dot ${i===carouselIndex?'active':''}"></span>`).join('')}</div></aside></div>`;
    $('#prevCar').onclick = () => { carouselIndex = (carouselIndex - 1 + rows.length) % rows.length; renderCarousel(); };
    $('#nextCar').onclick = () => { carouselIndex = (carouselIndex + 1) % rows.length; renderCarousel(); };
  }

  function renderTable(){
    const rows = filteredData();
    $('#tableBody').innerHTML = rows.map(r => `<tr><td>${esc(r.Fecha)}</td><td>${esc(r._format)}</td><td>${pautaPill(r)}</td><td><b>${esc(r['Título pieza'])}</b><br><span class="muted">${esc(r.Categoría)} · ${esc(r['Pilar contenido'])}</span></td><td>${esc(r['Copy ≤25 palabras'])}</td><td>${esc(r.CTA)}</td><td>${esc(r.Campaña || '—')}</td><td>${r['Link producto']?`<a href="${esc(r['Link producto'])}" target="_blank" rel="noopener">Ver producto</a>`:'—'}</td><td>${r._slides.length ? r._slides.map((l,i)=>`<a href="${esc(l)}" target="_blank" rel="noopener">Slide ${i+1}</a>`).join('<br>') : 'Sin imagen'}</td></tr>`).join('');
  }

  function renderVerify(){
    const total = DATA.length;
    const june = DATA.filter(r => r.Mes === 'Junio').length;
    const july = DATA.filter(r => r.Mes === 'Julio').length;
    const missingTitle = DATA.filter(r => !r['Título pieza']).length;
    const missingDate = DATA.filter(r => !r._dateKey).length;
    const copyOver = DATA.filter(r => r._wordCount > 25).length;
    const missingImgs = DATA.filter(r => !r._slides.length).length;
    const linkCount = DATA.reduce((a,r)=>a+r._slides.length,0);
    const pautaSi = DATA.filter(r => r._pauta && (r._pauta.key === 'si' || r._pauta.key === 'remarketing')).length;
    const pautaNo = DATA.filter(r => r._pauta && r._pauta.key === 'no').length;
    const pautaPend = DATA.filter(r => r._pauta && r._pauta.key === 'pendiente').length;
    $('#verifyMount').innerHTML = `<div class="verify-grid"><div class="verify-card">Fuente activa<b class="${DATA_SOURCE.includes('falló')?'bad':'ok'}">${esc(DATA_SOURCE)}</b><div class="code">${esc(CONFIG.appsScriptUrl || 'Apps Script no configurado; usando GViz/CSV fallback')}</div></div><div class="verify-card">Total leído<b>${total}</b><span class="muted">Junio ${june}/24 · Julio ${july}/81</span></div><div class="verify-card">Estado julio<b class="${july===81?'ok':'bad'}">${july}/81</b><span class="muted">Debe coincidir con 36 historias, 15 carruseles, 12 posts y 18 reels.</span></div><div class="verify-card">Copies >25 palabras<b class="${copyOver?'bad':'ok'}">${copyOver}</b></div><div class="verify-card">Piezas sin imagen<b class="${missingImgs?'bad':'ok'}">${missingImgs}</b><span class="muted">Se resuelve llenando Link slide 1-6.</span></div><div class="verify-card">Links de imagen detectados<b>${linkCount}</b></div><div class="verify-card">Etiquetas de pauta<b>${pautaSi} sí · ${pautaNo} no · ${pautaPend} pend.</b><span class="muted">Se controla desde la columna Pauta.</span></div><div class="verify-card">Títulos vacíos<b class="${missingTitle?'bad':'ok'}">${missingTitle}</b></div><div class="verify-card">Fechas inválidas<b class="${missingDate?'bad':'ok'}">${missingDate}</b></div><div class="verify-card">CSV conectado<div class="code">${esc(CONFIG.publishedCsvUrl)}</div></div></div>`;
  }

  function groupBy(arr, fn){ return arr.reduce((acc,x)=>{ const k=fn(x)||'__'; (acc[k] ||= []).push(x); return acc; }, {}); }

  function bind(){
    setupLinks();
    setupMonths();
    $('#monthSelect').value = 'Julio';
    ['monthSelect','formatSelect','statusSelect','pautaSelect'].forEach(id => $('#'+id).addEventListener('change', () => { SELECTED_DAY=null; renderAll(); }));
    $('#searchInput').addEventListener('input', () => { SELECTED_DAY=null; renderAll(); });
    $('#refreshBtn').addEventListener('click', loadData);
    $('#verifyBtn').addEventListener('click', () => switchView('verifyView'));
    $$('.view-btn').forEach(b => b.addEventListener('click', () => switchView(b.dataset.view)));
    $('#manualBtn').addEventListener('click', () => $('#manualBox').classList.toggle('show'));
    $('#closeManual').addEventListener('click', () => $('#manualBox').classList.remove('show'));
    $('#applyManualCsv').addEventListener('click', () => {
      try{
        const rows = rowsToObjects(parseCsv($('#manualCsv').value));
        setData(rows, 'csv-manual');
        $('#manualBox').classList.remove('show');
      }catch(e){ showNotice('No se pudo procesar el CSV manual: ' + e.message); }
    });
  }

  function switchView(id){
    $$('.view').forEach(v => v.classList.toggle('active', v.id === id));
    $$('.view-btn').forEach(b => b.classList.toggle('active', b.dataset.view === id));
    if(id === 'verifyView') renderVerify();
  }

  bind();
  loadData();
})();
</script>
</body>
