<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>THP · Grilla de Contenido 2026</title>
  <meta name="description" content="Calendario editorial de Trekking House Perú conectado a Google Sheets, Apps Script y Drive." />
  <link rel="preconnect" href="https://docs.google.com" />
  <link rel="preconnect" href="https://trekkinghouseperu.pe" />
  <style>
    :root{
      --bg:#06140f;
      --bg2:#0b1f16;
      --panel:#10291d;
      --panel2:#143322;
      --green:#14532D;
      --green2:#1f6f3c;
      --blue:#1D4ED8;
      --cream:#F5F3EE;
      --white:#ffffff;
      --muted:#bed0c4;
      --muted2:#93a89b;
      --amber:#D97706;
      --red:#c2410c;
      --line:rgba(245,243,238,.14);
      --line2:rgba(20,83,45,.24);
      --shadow:0 22px 60px rgba(0,0,0,.28);
      --radius:22px;
      --max:1480px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:radial-gradient(circle at top left,rgba(29,78,216,.17),transparent 35%),linear-gradient(140deg,var(--bg) 0%,var(--bg2) 44%,#11341f 100%);color:var(--cream);min-height:100vh}
    a{color:inherit}
    button,input,select,textarea{font:inherit}
    .wrap{width:min(var(--max),calc(100% - 32px));margin:0 auto}
    .hero{padding:24px 0 18px;border-bottom:1px solid var(--line);position:sticky;top:0;background:rgba(6,20,15,.92);backdrop-filter:blur(18px);z-index:50}
    .hero-row{display:flex;gap:22px;align-items:center;justify-content:space-between}
    .brand{display:flex;gap:16px;align-items:center;min-width:0}
    .logoBox{width:74px;height:54px;border-radius:17px;background:var(--cream);display:grid;place-items:center;box-shadow:var(--shadow);overflow:hidden;padding:6px;flex:0 0 auto}
    .logoBox img{width:100%;height:100%;object-fit:contain;display:block}
